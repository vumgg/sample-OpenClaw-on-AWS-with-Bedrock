{
  "name": "jira-query",
  "version": "1.0.0",
  "description": "Query Jira issues and create tickets for the team",
  "author": "IT Team",
  "scope": "global",
  "requires": {
    "env": ["JIRA_API_TOKEN", "JIRA_BASE_URL"],
